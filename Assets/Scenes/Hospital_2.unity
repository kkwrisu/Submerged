  - text: "*Voc\xEA pressiona sua m\xE3o contra a cama, sentindo-a morna.*"
    nextNodeIndex: 1
    endDialogueHere: 0
    choices: []
  - text: "Com certeza tinha algu\xE9m aqui \xE0 pouco tempo. Eles devem ter evacuado
      todos os pacientes n\xE3o muito tempo atr\xE1s... "
    nextNodeIndex: 2
    endDialogueHere: 1
    choices: []
  triggerActionOnInteract: 0
  interactActionDebugMessage: 
  onInteract:
    m_PersistentCalls:
      m_Calls: []
