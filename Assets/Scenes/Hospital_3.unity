--- !u!114 &503231145
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 503231144}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bc88e98598e100f4594256635b4aff5f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Interactable
  interactableId: 
  dialogueNodes:
  - text: "Voc\xEA chegou ao fim da demo de Submerged!"
    nextNodeIndex: 1
    endDialogueHere: 0
    choices: []
  - text: "Isso \xE9 tudo que n\xF3s temos para mostrar por agora. Esperamos que
      tenha se divertido com o jogo!"
    nextNodeIndex: 2
    endDialogueHere: 0
    choices: []
  - text: "Sinta-se livre para deixar uma an\xE1lise na p\xE1gina no itch.io com
      sugest\xF5es e feedbacks. "
    nextNodeIndex: 3
    endDialogueHere: 0
    choices: []
  - text: "Por fim, agradecemos por ter dado uma chance para nosso pequeno projeto
      universit\xE1rio, feito com muito carinho e suor."
    nextNodeIndex: 4
    endDialogueHere: 0
    choices: []
  - text: Obrigado por jogar!
    nextNodeIndex: 5
    endDialogueHere: 1
    choices: []
  triggerActionOnInteract: 0
  interactActionDebugMessage: 
  onInteract:
    m_PersistentCalls:
      m_Calls: []
