    hasHighlight: 1
    highlightEntries:
    - nodeType: 8
      highlightColor: {r: 1, g: 1, b: 1, a: 0}
    overridePosition: 0
    panelPosition: {x: 0, y: 0}
    overrideOverlayPosition: 0
    overlayPosition: {x: 0, y: 0}
  - title: Tutorial
    description: "Nem sempre ser\xE1 poss\xEDvel conectar duas fia\xE7\xF5es normalmente.
      Para isso, conecte o fio \xE0 uma conduite e continue o trajeto \xE0 partir
      de sua sa\xEDda. "
    hasHighlight: 1
    highlightEntries:
    - nodeType: 9
      highlightColor: {r: 1, g: 1, b: 1, a: 0}
    overridePosition: 1
    panelPosition: {x: 210, y: 75}
    overrideOverlayPosition: 1
    overlayPosition: {x: -913, y: 35}
  - title: Tutorial
    description: "Cuidado com inimigos por perto! Em caso de falha no conserto, voc\xEA
