    hasHighlight: 0
    highlightEntries:
    - nodeType: 3
      highlightColor: {r: 0, g: 0, b: 0, a: 0}
    overridePosition: 1
    panelPosition: {x: 459, y: -547}
    overrideOverlayPosition: 1
    overlayPosition: {x: -664, y: -587}
  - title: Tutorial
    description: "Conecte o fio \xE0 outra ponta para concluir o conserto."
    hasHighlight: 0
    highlightEntries:
    - nodeType: 4
      highlightColor: {r: 1, g: 1, b: 1, a: 0}
    overridePosition: 1
    panelPosition: {x: 210, y: 75}
    overrideOverlayPosition: 1
    overlayPosition: {x: -913, y: 35}
  - title: Tutorial
    description: Hazards Vermelhos destroem fios que passarem por casas adjacentes
